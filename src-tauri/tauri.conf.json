{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "cd frontend && npm run build",
    "beforeDevCommand": "cd frontend && npm run dev",
    "devPath": "http://localhost:3000",
    "distDir": "../frontend/out"
  },
  "package": { "productName": "Algae Desktop v4.0", "version": "0.1.0" },
  "tauri": {
    "allowlist": { "all": false, "shell": { "all": false, "open": true } },
    "bundle": { "active": true, "targets": ["msi"] },
    "systemTray": { "iconPath": "icons/icon.png", "iconAsTemplate": false }
  }
}
